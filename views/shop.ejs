<%- include('partials/header') %>

<section class="section" style="padding-bottom: 0;">
  <form action="/shop" method="GET" class="filter-form contact-panel" style="display: flex; flex-wrap: wrap; align-items: flex-end; gap: 24px; max-width: 100%;">
    <div class="form-group" style="flex: 2; min-width: 250px;">
      <label for="search">Search Parts</label>
      <input id="search" type="search" name="search" value="<%= search %>" placeholder="e.g. Brake pads, Civic, oil...">
    </div>
    <div class="form-group" style="flex: 1; min-width: 200px;">
      <label for="category">Category</label>
      <select id="category" name="category">
        <option value="All" <%= selectedCategory === 'All' ? 'selected' : '' %>>All categories</option>
        <% categories.forEach((category) => { %>
          <option value="<%= category %>" <%= selectedCategory === category ? 'selected' : '' %>><%= category %></option>
        <% }) %>
      </select>
    </div>
    <button class="btn btn-primary" type="submit">Filter Results</button>
  </form>
</section>

<section id="products" class="section product-section">
  <div class="section-header">
    <p class="eyebrow">Parts catalog</p>
    <h2>Available vehicle parts</h2>
  </div>

  <% if (products.length === 0) { %>
    <div class="empty-state">
      <h3>No parts found</h3>
      <p>Try a different keyword or category.</p>
    </div>
  <% } %>

  <div class="product-grid">
    <% products.forEach((product) => { %>
      <article class="product-card">
        <img src="<%= product.image %>" alt="<%= product.name %>">
        <div class="product-card-body">
          <p class="product-category"><%= product.category %></p>
          <h3><%= product.name %></h3>
          <p><%= product.vehicle %></p>
          <div class="product-meta">
            <div class="price-box">
              <% if (product.originalPrice && product.originalPrice > product.price) { %>
                <del class="original-price"><%= money(product.originalPrice) %></del>
              <% } %>
              <strong><%= money(product.price) %></strong>
            </div>
            <span class="stock-badge"><%= product.stock %> in stock</span>
          </div>
          <div class="card-actions">
            <a class="btn btn-secondary" href="/product/<%= product.id %>">Details</a>
            <a class="btn btn-primary" href="<%= whatsappLink(product) %>" target="_blank" rel="noopener">WhatsApp</a>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>