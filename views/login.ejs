<%- include('partials/header') %>

<main>
  <section class="section login-section">
    <div class="contact-panel login-panel-wrapper">
      <div class="section-header">
        <p class="eyebrow">Admin access</p>
        <h2>Management Login</h2>
      </div>
      
      <form method="POST" action="/admin/login" class="newsletter-form">
        <% if (error) { %>
          <p class="form-message" style="color: #ff4444; margin-bottom: 10px;">Incorrect password. Please try again.</p>
        <% } %>
        
        <div class="form-group">
          <label for="password">Administrator Password</label>
          <input id="password" type="password" name="password" placeholder="Enter your password" required autofocus>
        </div>
        
        <button class="btn btn-primary" type="submit">Login to Dashboard</button>
      </form>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
