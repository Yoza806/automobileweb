<%- include('partials/header') %>

<section class="admin-layout">
  <div class="admin-topbar">
    <form method="POST" action="/admin/logout">
      <button class="button secondary" type="submit">Logout</button>
    </form>
  </div>

  <div class="admin-form-panel">
    <p class="eyebrow">Admin page</p>
    <h1><%= editingProduct ? 'Edit product' : 'Add product' %></h1>

    <!-- ✅ IMPORTANT CHANGE: enctype added -->
    <form 
      method="POST" 
      action="<%= editingProduct ? '/admin/products/' + editingProduct.id + '/update' : '/admin/products' %>" 
      class="admin-form"
      enctype="multipart/form-data"
    >

      <label>
        <span>Product name</span>
        <input type="text" name="name" value="<%= editingProduct ? editingProduct.name : '' %>" required>
      </label>

      <label>
        <span>Category</span>
        <select name="category" required>
          <% categories.forEach((category) => { %>
            <option value="<%= category %>" <%= editingProduct && editingProduct.category === category ? 'selected' : '' %>><%= category %></option>
          <% }) %>
        </select>
      </label>

      <label>
        <span>Vehicle fitment</span>
        <input type="text" name="vehicle" value="<%= editingProduct ? editingProduct.vehicle : '' %>" required>
      </label>

      <div class="form-row">
        <label>
          <span>Original Price (LKR)</span>
          <input type="number" name="originalPrice" min="0" step="0.01" value="<%= editingProduct ? editingProduct.originalPrice : '' %>" placeholder="Price before discount">
        </label>

        <label>
          <span>Selling Price (LKR)</span>
          <input type="number" name="sellingPrice" min="0" step="0.01" value="<%= editingProduct ? editingProduct.price : '' %>" required>
        </label>

        <label>
          <span>Stock</span>
          <input type="number" name="stock" min="0" step="1" value="<%= editingProduct ? editingProduct.stock : '' %>" required>
        </label>
      </div>

      <!-- 🔥 REPLACED THIS SECTION -->
      <label>
        <span>Upload Product Image</span>
        <input type="file" name="image" accept="image/*" <%= editingProduct ? '' : 'required' %>>
      </label>

      <!-- 👇 Optional: show current image when editing -->
      <% if (editingProduct && editingProduct.image) { %>
        <div style="margin-top: 10px;">
          <p>Current Image:</p>
          <img src="<%= editingProduct.image %>" style="width: 120px; border-radius: 8px;">
        </div>
      <% } %>

      <label>
        <span>Description</span>
        <textarea name="description" rows="4" required><%= editingProduct ? editingProduct.description : '' %></textarea>
      </label>

      <div class="form-actions">
        <button class="button primary" type="submit">
          <%= editingProduct ? 'Update product' : 'Add product' %>
        </button>

        <% if (editingProduct) { %>
          <a class="button secondary" href="/admin">Cancel</a>
        <% } %>
      </div>
    </form>
  </div>

  <div class="admin-table-panel">
    <div class="section-heading">
      <p class="eyebrow">Inventory</p>
      <h2>Product list</h2>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Part</th>
            <th>Category</th>
            <th>Original</th>
            <th>Selling</th>
            <th>Stock</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody>
          <% products.forEach((product) => { %>
            <tr>
              <td>
                <strong><%= product.name %></strong>
                <small><%= product.vehicle %></small>
              </td>

              <td><%= product.category %></td>

              <td>
                <% if (product.originalPrice && product.originalPrice > 0) { %>
                  <del><%= money(product.originalPrice) %></del>
                <% } else { %>
                  <span class="muted">-</span>
                <% } %>
              </td>

              <td><strong><%= money(product.price) %></strong></td>

              <td><%= product.stock %></td>

              <td class="table-actions">
                <a class="button secondary" href="/admin/edit/<%= product.id %>">Edit</a>

                <form 
                  method="POST" 
                  action="/admin/products/<%= product.id %>/delete"
                  onsubmit="return confirm('Are you sure you want to delete this product? This action cannot be undone.');"
                >
                  <button class="button danger" type="submit">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>

      </table>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
