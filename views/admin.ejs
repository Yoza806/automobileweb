<%- include('partials/header') %>

<main class="admin-dashboard-container">
  <div class="admin-header">
    <h1>Inventory Management</h1>
    <form action="/admin/logout" method="POST">
      <button class="btn btn-secondary" type="submit">Logout</button>
    </form>
  </div>

  <div class="admin-grid">
    <!-- Form Side: Management Controls -->
    <section class="admin-card">
      <h3 style="margin-bottom: 20px;"><%= editingProduct ? 'Edit Product' : 'Add New Product' %></h3>
      <form 
        action="<%= editingProduct ? '/admin/products/' + editingProduct.id + '/update' : '/admin/products' %>" 
        method="POST" 
        enctype="multipart/form-data"
        class="admin-form"
      >
        <div class="form-group">
          <label>Product Name</label>
          <input type="text" name="name" value="<%= editingProduct ? editingProduct.name : '' %>" required placeholder="e.g. Performance Brake Pads">
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>Category</label>
            <select name="category">
              <% categories.forEach(cat => { %>
                <option value="<%= cat %>" <%= (editingProduct && editingProduct.category === cat) ? 'selected' : '' %>><%= cat %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Stock Count</label>
            <input type="number" name="stock" value="<%= editingProduct ? editingProduct.stock : '0' %>" required>
          </div>
        </div>

        <div class="form-group">
          <label>Vehicle Compatibility</label>
          <input type="text" name="vehicle" value="<%= editingProduct ? editingProduct.vehicle : '' %>" required placeholder="e.g. Toyota Corolla 2020+">
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>Original Price</label>
            <input type="number" step="0.01" name="originalPrice" value="<%= editingProduct ? editingProduct.originalPrice : '' %>">
          </div>
          <div class="form-group">
            <label>Selling Price</label>
            <input type="number" step="0.01" name="sellingPrice" value="<%= editingProduct ? editingProduct.price : '' %>" required>
          </div>
        </div>

        <div class="form-group">
          <label>Description</label>
          <textarea name="description" rows="4" required><%= editingProduct ? editingProduct.description : '' %></textarea>
        </div>

        <div class="form-group">
          <label>Product Images (Max 3) <%= editingProduct ? '(Optional if keeping old)' : '' %></label>
          <input type="file" name="images" multiple <%= editingProduct ? '' : 'required' %>>
        </div>

        <button class="btn btn-primary" type="submit" style="width: 100%;">
          <%= editingProduct ? 'Update Inventory' : 'Add to Inventory' %>
        </button>
        
        <% if (editingProduct) { %>
          <a href="/admin" class="btn btn-secondary" style="width: 100%; margin-top: 10px; display: block; text-align: center;">Cancel Edit</a>
        <% } %>
      </form>
    </section>

    <!-- Table Side: Product List -->
    <section class="admin-table-res table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Product Details</th>
            <th>Catagory</th>
            <th>Price</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(product => { %>
            <tr>
              <td>
                <div style="display: flex; align-items: center; gap: 12px;">
                  <img src="<%= product.image %>" alt="" style="width: 44px; height: 44px; border-radius: 6px; object-fit: cover; border: 1px solid var(--line);">
                  <div>
                    <strong style="display: block; font-size: 0.95rem;"><%= product.name %></strong>
                    <span style="font-size: 0.75rem; color: var(--muted);"><%= product.vehicle %></span>
                  </div>
                </div>
              </td>
              <td><span class="tag"><%= product.category %></span></td>
              <td>
                <div style="font-weight: bold; color: var(--blue);"><%= money(product.price) %></div>
                <small style="color: <%= product.stock < 5 ? 'var(--orange)' : 'var(--muted)' %>"><%= product.stock %> in stock</small>
              </td>
              <td>
                <div class="admin-actions">
                  <a href="/admin/edit/<%= product.id %>" class="btn btn-secondary" style="min-height: 34px; padding: 0 10px; font-size: 0.8rem;">Edit</a>
                  <form action="/admin/products/<%= product.id %>/delete" method="POST" onsubmit="return confirm('Delete this product permanently?')">
                    <button class="btn btn-danger" style="min-height: 34px; padding: 0 10px; font-size: 0.8rem;" type="submit">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </div>
</main>

<%- include('partials/footer') %>