<%- include('partials/header') %>

<main>
  <section class="section admin-layout">
  <div class="admin-topbar">
    <form method="POST" action="/admin/logout">
      <button class="btn btn-secondary" type="submit">Logout</button>
    </form>
  </div>

  <div class="admin-form-panel contact-panel">
    <div class="section-header">
      <p class="eyebrow">Inventory Management</p>
      <h2><%= editingProduct ? 'Update Listing' : 'Add New Product' %></h2>
    </div>

    <!-- ✅ IMPORTANT CHANGE: enctype added -->
    <form 
      method="POST" 
      action="<%= editingProduct ? '/admin/products/' + editingProduct.id + '/update' : '/admin/products' %>" 
      class="admin-form"
      enctype="multipart/form-data"
    >

      <div class="form-group">
        <label for="productName">Product Name</label>
        <input id="productName" type="text" name="name" value="<%= editingProduct ? editingProduct.name : '' %>" placeholder="e.g., Performance Brake Pads" required>
      </div>

      <div class="form-group">
        <label for="category">Category</label>
        <select id="category" name="category" required>
          <% categories.forEach((category) => { %>
            <option value="<%= category %>" <%= editingProduct && editingProduct.category === category ? 'selected' : '' %>><%= category %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="vehicle">Vehicle Fitment</label>
        <input id="vehicle" type="text" name="vehicle" value="<%= editingProduct ? editingProduct.vehicle : '' %>" placeholder="e.g., Toyota Supra MK4" required>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="originalPrice">Original Price (LKR)</label>
          <input id="originalPrice" type="number" name="originalPrice" min="0" step="0.01" value="<%= editingProduct ? editingProduct.originalPrice : '' %>" placeholder="Before discount">
        </div>

        <div class="form-group">
          <label for="sellingPrice">Selling Price (LKR)</label>
          <input id="sellingPrice" type="number" name="sellingPrice" min="0" step="0.01" value="<%= editingProduct ? editingProduct.price : '' %>" required>
        </div>

        <div class="form-group">
          <label for="stock">Stock Available</label>
          <input id="stock" type="number" name="stock" min="0" step="1" value="<%= editingProduct ? editingProduct.stock : '' %>" required>
        </div>
      </div>

      <div class="form-group">
        <label for="image">Upload Product Image</label>
        <input id="image" type="file" name="image" accept="image/*" <%= editingProduct ? '' : 'required' %>>
      </div>

      <% if (editingProduct && editingProduct.image) { %>
        <div style="margin-top: 10px;">
          <p>Current Image:</p>
          <img src="<%= editingProduct.image %>" style="width: 120px; border-radius: 8px;">
        </div>
      <% } %>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="4" placeholder="Detail compatibility, brand, and condition..." required><%= editingProduct ? editingProduct.description : '' %></textarea>
      </div>

      <div class="form-actions">
        <button class="btn btn-primary" type="submit">
          <%= editingProduct ? 'Update product' : 'Add product' %>
        </button>

        <% if (editingProduct) { %>
          <a class="btn btn-secondary" href="/admin">Cancel</a>
        <% } %>
      </div>
    </form>
  </div>

  <div class="admin-table-panel section">
    <div class="section-header">
      <p class="eyebrow">Inventory</p>
      <h2>Current Catalog</h2>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Part</th>
            <th>Category</th>
            <th>Original</th>
            <th>Selling Price</th>
            <th>Stock</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody>
          <% products.forEach((product) => { %>
            <tr>
              <td>
                <strong><%= product.name %></strong>
                <small><%= product.vehicle %></small>
              </td>

              <td><%= product.category %></td>

              <td>
                <% if (product.originalPrice && product.originalPrice > 0) { %>
                  <del><%= money(product.originalPrice) %></del>
                <% } else { %>
                  <span class="muted">-</span>
                <% } %>
              </td>

              <td><strong><%= money(product.price) %></strong></td>

              <td><%= product.stock %></td>

              <td class="table-actions">
                <a class="btn btn-secondary" href="/admin/edit/<%= product.id %>">Edit</a>

                <form 
                  method="POST" 
                  action="/admin/products/<%= product.id %>/delete"
                  onsubmit="return confirm('Are you sure you want to delete this product? This action cannot be undone.');"
                >
                  <button class="btn btn-danger" type="submit">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>

      </table>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
