<%- include('partials/header') %>

<section class="section">
  <div class="product-detail">
    <div class="product-gallery">
      <div class="img-carousel-container" data-images="<%= product.images.filter(img => !!img).join(',') %>" data-current-index="0">
        <img src="<%= product.image %>" alt="<%= product.name %>" class="carousel-img">
        <% if (product.images.length > 1) { %>
          <button type="button" class="carousel-arrow prev">‹</button>
          <button type="button" class="carousel-arrow next">›</button>
        <% } %>
      </div>
      <% if (product.images.length > 1) { %>
        <div class="thumbnail-grid">
          <% product.images.forEach((img, index) => { %>
            <button type="button" class="thumbnail-item <%= index === 0 ? 'active' : '' %>" data-index="<%= index %>">
              <img src="<%= img %>" alt="">
            </button>
          <% }) %>
        </div>
      <% } %>
    </div>
    <div class="product-detail-copy">
    <p class="eyebrow"><%= product.category %></p>
    <h1><%= product.name %></h1>
    <p class="detail-vehicle"><%= product.vehicle %></p>
    <p><%= product.description %></p>
    <div class="detail-price">
      <% if (product.originalPrice && product.originalPrice > product.price) { %>
        <del class="original-price"><%= money(product.originalPrice) %></del>
      <% } %>
      <strong class="selling-price"><%= money(product.price) %></strong>
      <span><%= product.stock %> in stock</span>
    </div>
    <a class="btn btn-primary detail-order" href="<%= whatsappLink(product) %>" target="_blank" rel="noopener">Order through WhatsApp</a>
  </div>
</section>

<%- include('partials/footer') %>
