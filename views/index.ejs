        </div>
        <div class="trust-badges" aria-label="Trust badges">
          <div class="badge">
            <span class="badge-icon">&#10003;</span>
            <span>Warranty backed</span>
          </div>
          <div class="badge">
            <span class="badge-icon">&#9670;</span>
